NODE_ENV=production
PORT=8080

# Public Electron origins allowed to call HTTP endpoints and open /ws.
# For packaged Electron builds using this repo, keep app://kaplia-meet.
ALLOWED_ORIGINS=app://kaplia-meet,http://localhost:5173,http://127.0.0.1:5173
ALLOW_NO_ORIGIN=false

# Room creation rate limit per IP.
CREATE_ROOM_LIMIT_PER_MINUTE=20
ROOM_EMPTY_TTL_SECONDS=900

# TURN REST API compatible credentials. Use the same secret in coturn static-auth-secret.
# Leave empty for local development without coturn.
TURN_HOST=meet.kaplia.pro
TURN_REALM=meet.kaplia.pro
TURN_SECRET=
TURN_TTL_SECONDS=3600
TURN_TLS_ENABLED=false
