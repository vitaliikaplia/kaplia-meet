# Copy this file to deploy/coturn/turnserver.conf and replace placeholders.
# Use the same TURN_SECRET value in server/.env as static-auth-secret here.

listening-port=3478
tls-listening-port=5349
listening-ip=0.0.0.0
relay-ip=0.0.0.0
external-ip=167.233.126.127

realm=meet.kaplia.pro
server-name=meet.kaplia.pro

fingerprint
lt-cred-mech
use-auth-secret
static-auth-secret=REPLACE_WITH_THE_SAME_TURN_SECRET_FROM_SERVER_ENV
stale-nonce=600

no-loopback-peers
no-multicast-peers
no-cli

min-port=49152
max-port=65535

total-quota=100
user-quota=4

# Enable these only after mounting valid certificate files into the coturn container.
# cert=/etc/coturn/certs/fullchain.pem
# pkey=/etc/coturn/certs/privkey.pem
